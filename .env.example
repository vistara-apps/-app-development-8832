# Study & Style Environment Variables
# Copy this file to .env and fill in your actual values

# OpenAI API Configuration
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Cloudinary Configuration
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset
VITE_CLOUDINARY_API_KEY=your_cloudinary_api_key

# Farcaster Configuration (for Frame integration)
VITE_FARCASTER_HUB_URL=https://hub.farcaster.xyz
VITE_FARCASTER_APP_FID=your_app_fid

# Base Network Configuration
VITE_BASE_RPC_URL=https://mainnet.base.org
VITE_BASE_CHAIN_ID=8453

# Payment Configuration
VITE_PAYMENT_API_URL=https://payments.vistara.dev

# App Configuration
VITE_APP_NAME=Study & Style
VITE_APP_VERSION=1.0.0
VITE_APP_ENVIRONMENT=development

# Analytics (optional)
VITE_ANALYTICS_ID=your_analytics_id

# Feature Flags
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_PAYMENTS=true
VITE_ENABLE_FARCASTER=true
VITE_ENABLE_ANALYTICS=false
